<?xml version="1.0"?>
<robot name="four_wheel_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.125"/>
      <geometry>
        <box size="0.70 0.50 0.25"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.125"/>
      <geometry>
        <box size="0.70 0.50 0.25"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.125"/>
      <mass value="87.5"/>
      <inertia ixx="2.2" iyy="4.0" izz="5.3" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ================= WHEEL MACRO ================= -->
  <xacro:macro name="wheel" params="name x y">

    <link name="${name}">
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="0.12" length="0.05"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="0.12" length="0.05"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="2.26"/>
        <inertia ixx="0.008" iyy="0.016" izz="0.008" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} 0.12"/>
      <axis xyz="0 1 0"/>
    </joint>

  </xacro:macro>

  <!-- ================= CALL MACRO ================= -->
  <xacro:wheel name="front_left_wheel"  x="0.35"  y="0.275"/>
  <xacro:wheel name="front_right_wheel" x="0.35"  y="-0.275"/>
  <xacro:wheel name="rear_left_wheel"   x="-0.35" y="0.275"/>
  <xacro:wheel name="rear_right_wheel"  x="-0.35" y="-0.275"/>

</robot>