<?xml version="1.0"?>
<!--
  2-DOF Robotic Arm URDF
  =======================
  Hierarchy : base_link  ->  link1  ->  link2
  Joints    : revolute (Z-axis), limits ±3.14 rad
  Density   : 1000 kg/m³

  base_link : pedestal cylinder  r=0.06 m, h=0.10 m
  link1     : arm cylinder       r=0.04 m, l=0.40 m
  link2     : arm cylinder       r=0.03 m, l=0.30 m

  Each link's origin is at its base (joint attachment point).
  Arm extends along the X-axis; joints rotate about Z.
-->
<robot name="robo_arm">

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <!--
      Pedestal cylinder (r=0.06, h=0.10)
      Volume = 0.001131 m³,  Mass = 1.1310 kg
      Izz = m/2 · r²           = 0.002036
      Ixx = Iyy = m/12·(3r²+h²) = 0.001960
    -->
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.10"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.10"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="1.1310"/>
      <inertia ixx="0.001960" ixy="0" ixz="0"
               iyy="0.001960" iyz="0"
               izz="0.002036"/>
    </inertial>
  </link>

  <!-- ==================== JOINT 1 ==================== -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <!-- ==================== LINK 1 ==================== -->
  <link name="link1">
    <!--
      Arm cylinder (r=0.04, l=0.40) extending along X.
      Volume = 0.002011 m³,  Mass = 2.0106 kg
      Ixx = m/2 · r²            = 0.001609
      Iyy = Izz = m/12·(3r²+l²) = 0.027620
    -->
    <!-- Cylinder axis is Z by default; rotate π/2 about Y to align with X -->
    <visual>
      <origin xyz="0.20 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.40"/>
      </geometry>
      <material name="orange">
        <color rgba="0.9 0.5 0.1 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0.20 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.40"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0.20 0 0" rpy="0 0 0"/>
      <mass value="2.0106"/>
      <inertia ixx="0.001609" ixy="0" ixz="0"
               iyy="0.027620" iyz="0"
               izz="0.027620"/>
    </inertial>
  </link>

  <!-- ==================== JOINT 2 ==================== -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <!-- Placed at the end of link1 (0.40 m along X) -->
    <origin xyz="0.40 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <!-- ==================== LINK 2 ==================== -->
  <link name="link2">
    <!--
      Arm cylinder (r=0.03, l=0.30) extending along X.
      Volume = 0.000848 m³,  Mass = 0.8482 kg
      Ixx = m/2 · r²            = 0.000382
      Iyy = Izz = m/12·(3r²+l²) = 0.006554
    -->
    <visual>
      <origin xyz="0.15 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.30"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.2 0.2 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0.15 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.30"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0.15 0 0" rpy="0 0 0"/>
      <mass value="0.8482"/>
      <inertia ixx="0.000382" ixy="0" ixz="0"
               iyy="0.006554" iyz="0"
               izz="0.006554"/>
    </inertial>
  </link>

</robot>
